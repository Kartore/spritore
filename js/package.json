{
	"name": "@kartore/spritore",
	"version": "0.1.1",
	"description": "Generate MapLibre sprite sheets from SVG icons in browsers, Node, and the command line",
	"type": "module",
	"bin": {
		"spritore": "./cli.mjs"
	},
	"exports": {
		".": {
			"types": "./index.d.ts",
			"import": "./index.mjs",
			"default": "./index.mjs"
		},
		"./node": {
			"types": "./index.d.ts",
			"import": "./node.mjs",
			"default": "./node.mjs"
		}
	},
	"types": "./index.d.ts",
	"files": [
		"cli.mjs",
		"index.mjs",
		"node.mjs",
		"index.d.ts",
		"pkg/"
	],
	"scripts": {
		"build": "node scripts/build.mjs",
		"test": "node --test test/",
		"bench": "node test/bench.mjs"
	},
	"license": "MIT OR Apache-2.0",
	"repository": {
		"type": "git",
		"url": "https://github.com/Kartore/spritore.git",
		"directory": "js"
	},
	"devDependencies": {},
	"packageManager": "pnpm@11.13.1",
	"devEngines": {
		"runtime": {
			"name": "node",
			"version": "26.5.0",
			"onFail": "download"
		}
	}
}
