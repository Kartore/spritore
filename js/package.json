{
	"name": "@kartore/spritore",
	"version": "0.2.0",
	"description": "Generate MapLibre sprite sheets from SVG icons in browsers, Node, and the command line",
	"type": "module",
	"bin": {
		"spritore": "./dist/cli.js"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		},
		"./node": {
			"types": "./dist/node.d.ts",
			"import": "./dist/node.js",
			"default": "./dist/node.js"
		}
	},
	"types": "./dist/index.d.ts",
	"files": [
		"dist/",
		"pkg/"
	],
	"scripts": {
		"build": "node scripts/build.mjs",
		"typecheck": "tsc --project tsconfig.json --noEmit && tsc --project test/tsconfig.json && tsc --project test/types/browser/tsconfig.json && tsc --project test/types/node/tsconfig.json",
		"test": "node --test \"test/*.test.ts\"",
		"bench": "node test/bench.ts"
	},
	"license": "MIT OR Apache-2.0",
	"repository": {
		"type": "git",
		"url": "https://github.com/Kartore/spritore.git",
		"directory": "js"
	},
	"devDependencies": {
		"@types/node": "26.1.1",
		"typescript": "7.0.2"
	}
}
